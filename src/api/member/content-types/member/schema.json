{
  "kind": "collectionType",
  "collectionName": "members",
  "info": {
    "singularName": "member",
    "pluralName": "members",
    "displayName": "Member"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "FullName": {
      "type": "string"
    },
    "memberID": {
      "type": "string"
    },
    "branch": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::branch.branch"
    },
    "Email": {
      "type": "email"
    },
    "PhoneNumber": {
      "type": "string"
    },
    "MemberStatus": {
      "type": "enumeration",
      "enum": [
        "Active",
        "Inactive",
        "Archived"
      ]
    },
    "Category": {
      "type": "enumeration",
      "enum": [
        "Regular",
        "Visitor",
        "New Convert"
      ]
    },
    "branches": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::branch.branch"
    }
  }
}
